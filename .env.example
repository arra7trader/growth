# Runtime mode
AETHER_REAL_MODE=true
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
# Needed for direct auto-submit to GitHub issues (if empty, engine uses outbox mode)
GITHUB_TOKEN=
GITHUB_OWNER=arra7trader
GITHUB_REPO=growth

# Local database (free)
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# Real affiliate links JSON (replace with your real partner links)
# Example:
# AFFILIATE_LINKS_JSON=[{"keyword":"hosting","affiliateUrl":"https://partner.example.com/offer?id=abc","conversionRate":0.03}]
AFFILIATE_LINKS_JSON=

# USDT payout destination (default: your BEP20 wallet)
AETHER_PAYOUT_USDT_BEP20_ADDRESS=0x84a06ffc26031b782c893252a769bd146bca8ad0
AETHER_PAYOUT_NETWORK=BEP20
AETHER_PAYOUT_TOKEN=USDT
USDT_BSC_CONTRACT=0x55d398326f99059fF775485246999027B3197955
BSC_RPC_URL=https://bsc-dataseed.binance.org
BSC_RPC_URLS=https://bsc-dataseed.binance.org,https://bsc-rpc.publicnode.com,https://rpc.ankr.com/bsc
ONCHAIN_MAX_BLOCKS_PER_SYNC=120
ONCHAIN_MIN_SYNC_INTERVAL_SECONDS=120
ONCHAIN_RATE_LIMIT_COOLDOWN_SECONDS=300

# Pilot bot automation
PILOT_INTERVAL_MINUTES=30
PILOT_EVOLUTION_INTERVAL_MINUTES=180
PILOT_MAX_CYCLES=0
PILOT_FORCE_FIRST_EVOLUTION=true
PILOT_OPERATION_MODE=free_autonomous
PILOT_REPORT_DIR=reports/pilot
PILOT_WRITE_REPORTS=true

# App settings
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
